#!/usr/bin/env bash
# pre-push: single-remote workflow guard
#
# Install: git config core.hooksPath scripts/hooks

remote="$1"

if [[ "$remote" != "origin" ]]; then
  echo ""
  echo "  BLOCKED: this workspace is configured for a single origin remote."
  echo "  Push to '$remote' has been disabled."
  echo ""
  echo "  Use:"
  echo "    git push origin <branch>"
  echo ""
  exit 1
fi

exit 0
