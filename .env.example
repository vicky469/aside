# SideNote2 DGX bridge example environment

SIDENOTE2_DGX_BIND_HOST=127.0.0.1
SIDENOTE2_DGX_PORT=4215
SIDENOTE2_DGX_PUBLIC_BASE_URL=http://127.0.0.1:4215
SIDENOTE2_DGX_WORKSPACE_ROOT=.dgx-workspace

# Bridge authentication
SIDENOTE2_DGX_BRIDGE_BEARER_TOKEN=replace-with-a-long-random-token

# Access and allowance
# Future option if we later support non-token allowance identities:
# SIDENOTE2_DGX_ALLOWANCE_IDENTITY_MODE=bridge_token
SIDENOTE2_DGX_FREE_ALLOWANCE_ENABLED=true
SIDENOTE2_DGX_FREE_ALLOWANCE_RUNS_PER_DAY=50

# Codex runtime
SIDENOTE2_DGX_CODEX_BIN=codex
