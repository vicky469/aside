# Aside DGX bridge example environment

ASIDE_DGX_BIND_HOST=127.0.0.1
ASIDE_DGX_PORT=4215
ASIDE_DGX_PUBLIC_BASE_URL=http://127.0.0.1:4215
ASIDE_DGX_WORKSPACE_ROOT=.dgx-workspace

# Bridge authentication
ASIDE_DGX_BRIDGE_BEARER_TOKEN=replace-with-a-long-random-token

# Access and allowance
# Future option if we later support non-token allowance identities:
# ASIDE_DGX_ALLOWANCE_IDENTITY_MODE=bridge_token
ASIDE_DGX_FREE_ALLOWANCE_ENABLED=true
ASIDE_DGX_FREE_ALLOWANCE_RUNS_PER_DAY=50

# Codex runtime
ASIDE_DGX_CODEX_BIN=codex
