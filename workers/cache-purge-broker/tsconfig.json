{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"noEmit": true,
		"lib": ["ES2022"],
		"skipLibCheck": true,
		"types": ["vitest/globals", "@cloudflare/vitest-pool-workers/types"]
	},
	"include": ["src/**/*.ts", "test/**/*.ts"]
}
