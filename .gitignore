# vscode
.vscode/

# Intellij
*.iml
.idea/

# npm
node_modules/
.npmrc
.env
.env.*
!.env.example

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js

# Exclude sourcemaps
*.map
*.tsbuildinfo
dist/
coverage/

# obsidian runtime state
data.json
/.obsidian/

# Exclude macOS Finder (System Explorer) View States
.DS_Store

# Local agent/dev notes and planning docs
.codex/
/AGENTS.md
/CLAUDE.md
/CONTEXT.md
/README-dev.md
/docs/*
!/docs/releases/
/docs/releases/*
!/docs/releases/_template.md
!/docs/releases/*.md

# Bundled public skill surface
/skills/*
!/skills/aside/
!/skills/aside/SKILL.md

# Test build output
.test-dist
.test-dist*
.aside-dev

# Generated plugin logs
/logs

# Dev vault sidecar artifacts (per-note comment storage)
/sidenotes

# Temporary local artifact exports
/.public-release

# Dev-only Obsidian skill references stay on the dedicated skills-dev branch
/skills/dev
